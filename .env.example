# Phase 2 environment variables — copy to .env and fill in. Never commit .env.

VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_replace_me

